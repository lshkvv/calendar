   <string>
    QMainWindow { background-color: #1e1e2e; }
    QTabWidget::pane { border: none; background: #1e1e2e; }
    QTabBar::tab {
      background: #2a2a3e;
      color: #aaa;
      padding: 10px 24px;
      font-size: 14px;
      border: none;
      margin-right: 2px;
    }
    QTabBar::tab:selected {
      background: #3d5a80;
      color: white;
      font-weight: bold;
      border-radius: 4px 4px 0 0;
    }
    QTableView {
      background: #252535;
      color: #e0e0e0;
      gridline-color: #3a3a4a;
      font-size: 13px;
      selection-background-color: #3d5a80;
      border: 1px solid #3a3a4a;
      border-radius: 6px;
    }
    QHeaderView::section {
      background: #2a2a3e;
      color: #aaa;
      padding: 6px;
      border: none;
      font-size: 13px;
    }
    QPushButton {
      background: #3d5a80;
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: 6px;
      font-size: 13px;
      min-width: 120px;
    }
    QPushButton:hover  { background: #4d6a90; }
    QPushButton:pressed{ background: #2d4a70; }
    QStatusBar { color: #888; background: #1e1e2e; font-size: 12px; }
    QLabel { color: #e0e0e0; }
    QCalendarWidget QWidget {
      alternate-background-color: #252535;
      background-color: #252535;
      color: #e0e0e0;
    }
    QCalendarWidget QToolButton {
      color: white;
      background-color: #3d5a80;
      border: none;
      margin: 4px;
      padding: 6px;
      border-radius: 4px;
    }
    QCalendarWidget QMenu {
      background-color: #2a2a3e;
      color: white;
    }
    QCalendarWidget QSpinBox {
      background: #252535;
      color: white;
      selection-background-color: #3d5a80;
    }
   </string>
