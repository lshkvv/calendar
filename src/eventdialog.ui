  <property name="styleSheet">
   <string>
    QDialog { background: #1e1e2e; }
    QLabel  { color: #ccc; font-size: 13px; }
    QLineEdit, QPlainTextEdit, QDateEdit, QTimeEdit, QComboBox {
      background: #252535;
      color: #e0e0e0;
      border: 1px solid #3a3a5a;
      border-radius: 5px;
      padding: 6px;
      font-size: 13px;
    }
    QLineEdit:focus, QPlainTextEdit:focus, QDateEdit:focus, QTimeEdit:focus, QComboBox:focus {
      border: 1px solid #3d5a80;
    }
    QCheckBox { color: #ccc; font-size: 13px; }
    QGroupBox {
      color: #98c1d9;
      font-size: 13px;
      border: 1px solid #3a3a5a;
      border-radius: 6px;
      margin-top: 8px;
      padding-top: 6px;
    }
    QGroupBox::title { subcontrol-origin: margin; left: 10px; }
    QListWidget {
      background: #252535;
      color: #e0e0e0;
      border: 1px solid #3a3a5a;
      border-radius: 5px;
      font-size: 13px;
    }
    QListWidget::item:hover   { background: #2d2d45; }
    QListWidget::item:selected{ background: #3d5a80; }
    QPushButton {
      background: #3d5a80;
      color: white;
      border: none;
      padding: 10px 28px;
      border-radius: 6px;
      font-size: 13px;
      min-width: 100px;
    }
    QPushButton:hover { background: #4d6a90; }
   </string>
  </property>
